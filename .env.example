# Kafka/Redpanda
KAFKA_BROKERS=localhost:19092
KAFKA_CONSUMER_GROUP=trading-journal
KAFKA_ORDERS_TOPIC=trading.orders

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=trader
DB_PASSWORD=REDACTED_PASSWORD
DB_NAME=trading_platform

# Telegram Journal Bot (create a separate bot for journaling)
TELEGRAM_JOURNAL_BOT_TOKEN=your_journal_bot_token_here
TELEGRAM_JOURNAL_CHAT_ID=your_chat_id_here

# Journal Settings
JOURNAL_PROMPT_TIMEOUT=60
